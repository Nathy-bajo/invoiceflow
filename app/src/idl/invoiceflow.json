    {
      "name": "Invoice",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "freelancer",
            "docs": [
              "Payee — the wallet that receives released funds."
            ],
            "type": "pubkey"
          },
          {
            "name": "client",
            "docs": [
              "Payer — `Pubkey::default()` until first funding."
