              "option": "pubkey"
            }
          },
          {
            "name": "invoice_id",
            "docs": [
              "Stable per-freelancer counter. Combined with `freelancer` to derive PDA."
            ],
            "type": "u64"
          },
          {
            "name": "total_amount",
            "docs": [
              "Sum of milestone.amount. Set at creation, never mutated."
            ],
            "type": "u64"
          },
          {
            "name": "released_amount",
            "docs": [
              "Sum of milestone.amount for milestones with released = true."
            ],
            "type": "u64"
          },
          {
            "name": "status",
            "type": {
              "defined": {
                "name": "InvoiceStatus"
              }
