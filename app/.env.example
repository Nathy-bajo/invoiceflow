## Required by the frontend at build time. Set these as Vercel project env vars
## (Production + Preview) and copy to .env.local for local dev.

# devnet | mainnet-beta | localnet
NEXT_PUBLIC_CLUSTER=devnet

# RPC endpoint used in the browser (wallet-adapter, transaction submission).
# For production use a private RPC (Helius / QuickNode / Triton) — public
# endpoints rate-limit aggressively.
NEXT_PUBLIC_RPC_ENDPOINT=https://api.devnet.solana.com

# Deployed program id. Must match the on-chain program. Synced via the
# `npm run sync-idl` script after `anchor deploy`.
NEXT_PUBLIC_PROGRAM_ID=DYkNRoH7goicxXzttxEALr6eRGp5EMkRxxpHQGYt3pAQ

## Server-only (not exposed to the browser). Used by the /api/invoices
## indexer cache and the /api/webhook receiver.

# RPC endpoint for the server-side indexer. Defaults to NEXT_PUBLIC_RPC_ENDPOINT
# if unset. Set this to a private Helius / QuickNode URL in production so the
# indexer cache misses don't compete with browser traffic on the public RPC.
SOLANA_RPC_URL=https://api.devnet.solana.com

# Shared secret protecting POST /api/webhook. When set, requests must send
# this value as the `Authorization` header (or `Bearer <secret>`). Configure
# the same value in your Helius webhook's Authentication Header field. If
# unset, the webhook accepts all requests (dev only — never deploy that way).
HELIUS_WEBHOOK_SECRET=replace-me-with-a-long-random-string
